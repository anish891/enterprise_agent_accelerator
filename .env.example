# ==============================================================================
# ENTERPRISE AGENT ORCHESTRATOR (crewctl) — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' in your project root and fill in your credentials.
# `crewctl` will automatically load variables from '.env' when present.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. LLM PROVIDERS (Set the API key for your chosen provider in config.yaml)
# ------------------------------------------------------------------------------

# --- OpenAI Direct ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Azure OpenAI (Default in config.yaml) ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Google Gemini ---
GEMINI_API_KEY=your-gemini-api-key

# ------------------------------------------------------------------------------
# 2. WEB & SEARCH CONNECTORS
# ------------------------------------------------------------------------------
SERPER_API_KEY=your-serper-api-key-for-google-search
ALPHAVANTAGE_API_KEY=your-alpha-vantage-api-key-for-stock-data

# ------------------------------------------------------------------------------
# 3. ENTERPRISE CONNECTORS
# ------------------------------------------------------------------------------

# --- Jira Connector ---
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=user@yourcompany.com
JIRA_TOKEN=your-jira-api-token

# --- ServiceNow Connector ---
SERVICENOW_INSTANCE=https://your-instance.service-now.com
SERVICENOW_USER=admin
SERVICENOW_TOKEN=your-servicenow-api-token

# --- Confluence Connector ---
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=user@yourcompany.com
CONFLUENCE_TOKEN=your-confluence-api-token

# --- SharePoint & Microsoft 365 Connector ---
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/mysite
SHAREPOINT_TOKEN=your-sharepoint-access-token
SHAREPOINT_CLIENT_ID=your-sharepoint-client-id
SHAREPOINT_CLIENT_SECRET=your-sharepoint-client-secret
SHAREPOINT_TENANT_ID=your-sharepoint-tenant-id

# --- Outlook Connector ---
OUTLOOK_CLIENT_ID=your-outlook-azure-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-azure-client-secret
OUTLOOK_TENANT_ID=your-outlook-azure-tenant-id

# --- SAP Connector ---
SAP_HOST=https://your-sap-system.company.com
SAP_API_KEY=your-sap-api-key
SAP_CLIENT=100

# ------------------------------------------------------------------------------
# 4. INFRASTRUCTURE & BACKENDS (Optional)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crewctl

# --- HashiCorp Vault (If secrets_backend: vault) ---
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=your-vault-token
VAULT_SECRET_PATH=secret/data/crewctl

# --- AWS Secrets Manager (If secrets_backend: aws) ---
AWS_DEFAULT_REGION=us-east-1
AWS_SECRET_NAME=crewctl
